configuration {
  modi: "drun,run,window";
  show-icons: true;
  drun-display-format: "{name}";
  display-drun: "apps";
  display-run: "run";
  display-window: "windows";
  icon-theme: "Papirus-Dark";
  terminal: "kitty";
  font: "Open Sans 14";
  location: 0;
  anchor: center;
  x-offset: 0;
  y-offset: -90;
  kb-accept-entry: "Return,KP_Enter";
  kb-remove-to-eol: "";
  kb-row-down: "Down,Control+j";
  kb-row-up: "Up,Control+k";
}

@theme "theme.rasi"
